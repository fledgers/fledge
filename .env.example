# Public Supabase settings used by the Vite frontend.
# These values are safe to expose in the browser when Row Level Security is on.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key-here

# Server-only Vercel Function settings. Never prefix the API key with VITE_.
ESTHA_API_KEY=your-estha-api-key-here
ESTHA_API_URL=https://studio.estha.ai/api/v1/open/chat/completions
# Add this only when Estha's generated API instructions require a model ID.
# ESTHA_MODEL_ID=your-estha-model-id
